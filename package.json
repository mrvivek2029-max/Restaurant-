{
  "name": "performance-optimization-demo",
  "version": "1.0.0",
  "description": "A demo application showcasing performance optimization techniques",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "npm run build && node analyze-bundle.js",
    "analyze:interactive": "npx vite-bundle-analyzer dist",
    "lighthouse": "npm run build && npm run preview & sleep 3 && lighthouse http://localhost:4173 --output html --output-path ./lighthouse-report.html && pkill -f 'vite preview'",
    "performance": "npm run build && npm run analyze && npm run lighthouse",
    "test": "jest"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "axios": "^1.3.0",
    "react-window": "^1.8.8",
    "web-vitals": "^3.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "vite": "^4.1.0",
    "vite-bundle-analyzer": "^0.7.0",
    "webpack-bundle-analyzer": "^4.7.0",
    "lighthouse": "^9.6.8",
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "babel-loader": "^9.1.2",
    "compression-webpack-plugin": "^10.0.0",
    "terser-webpack-plugin": "^5.3.6"
  },
  "keywords": ["performance", "optimization", "react", "bundle-size", "load-time"],
  "author": "Performance Optimization Demo",
  "license": "Apache-2.0"
}